PORT=5002

# Postgres connection — the zomato_db database with the restaurants2 table
DB_HOST=your_postgres_host
DB_PORT=5432
DB_NAME=zomato_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
# Set to "true" if your host requires SSL (most managed Postgres providers do)
DB_SSL=false

# Google AI Studio API key for Gemini (used for image-based food recognition)
GEMINI_API_KEY=your_gemini_api_key
